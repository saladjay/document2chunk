# 远程 PaddleOCR 服务配置（D11 ocr-extractor）
#
# 用法：复制本文件为 `.env`（已在 .gitignore，不会提交）并填入真实 token；
# OcrConfig.from_env() 会自动从 cwd 及上级目录的 .env 读取。
# 也可直接 export 这些变量（真实环境变量优先于 .env）。
# 变量名见 src/document2chunk/extractors/ocr/_config.py（澄清2 G19/G20）。

# 必填：服务访问 token（见 D:\project\server\PaddleOCR三件套使用文档.md）
DOCUMENT2CHUNK_OCR_TOKEN=your-token-here

# 服务地址（默认即下）
DOCUMENT2CHUNK_OCR_ENDPOINT=http://128.23.67.112:8000

# 可选：默认模型（vl | pp-ocrv6 | unlimited）
# DOCUMENT2CHUNK_OCR_MODEL=vl

# 可选：单次解析超时（秒）
# DOCUMENT2CHUNK_OCR_TIMEOUT=180

# 可选：失败重试次数
# DOCUMENT2CHUNK_OCR_MAX_RETRIES=3
